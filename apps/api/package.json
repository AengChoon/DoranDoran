{
  "name": "@dorandoran/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/client-sesv2": "^3.1042.0",
    "@dorandoran/db": "workspace:*",
    "@dorandoran/shared": "workspace:*",
    "@hono/node-server": "^2.0.1",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.4",
    "jose": "^6.2.3",
    "nanoid": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3"
  }
}
